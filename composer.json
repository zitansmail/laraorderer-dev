{
  "name": "zitansmail/migration-orderer",
  "description": "Order Laravel migrations before execution",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "MigrationOrderer\\": "src/",
      "Tests\\": "tests/"

    }
  },
  "require": {
    "php": "^8.1",
    "illuminate/database": "^10.0 || ^11.0 || ^12.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "MigrationOrderer\\MigrationOrdererServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "pestphp/pest": "^3.8"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
